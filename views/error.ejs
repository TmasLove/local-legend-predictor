<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Error – Local Legend Predictor</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="login-body">
  <div class="login-container">
    <div class="login-card" style="text-align:center">
      <div style="font-size:4rem;margin-bottom:1rem">😬</div>
      <h2 style="margin-bottom:1rem">Something went wrong</h2>
      <p style="color:#666;margin-bottom:2rem"><%= message %></p>
      <% if (user) { %>
        <a href="/dashboard" class="btn-strava" style="display:inline-block">← Back to Dashboard</a>
      <% } else { %>
        <a href="/login" class="btn-strava" style="display:inline-block">← Back to Login</a>
      <% } %>
    </div>
  </div>
</body>
</html>
