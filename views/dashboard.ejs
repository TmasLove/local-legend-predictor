<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Your Segments – Personal Effort Tracker</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="dashboard-body">

  <!-- Nav -->
  <nav class="navbar">
    <div class="nav-inner">
      <div class="nav-brand">
        <span class="bike-sm">🚴</span>
        <span>Personal <span class="orange">Effort Tracker</span></span>
      </div>
      <div class="nav-right">
        <% if (user && user.photo) { %>
          <img class="avatar" src="<%= user.photo %>" alt="<%= user.name %>">
        <% } %>
        <span class="nav-name"><%= user ? user.firstName || user.name : '' %></span>
        <form method="POST" action="/logout" style="display:inline;">
          <button type="submit" class="btn-logout">Log out</button>
        </form>
      </div>
    </div>
  </nav>

  <main class="main">
    <div class="page-header">
      <h1>Your Top Segments <span class="badge">Last 90 days</span></h1>
      <p class="sub">Your own efforts — set personal goals and track your progress.</p>
    </div>

    <% if (error) { %>
      <div class="alert alert-warning" style="max-width:760px;margin:0 auto 2rem;">
        ⚠️  <%= error %>
      </div>
    <% } %>

    <% if (segments && segments.length > 0) { %>
      <div class="segments-grid">
        <% segments.forEach((seg, idx) => { %>
          <div class="segment-card">

            <!-- Rank badge -->
            <div class="rank-badge">#<%= idx + 1 %></div>

            <h2 class="seg-name"><%= seg.name %></h2>

            <!-- Stats row: current vs last year -->
            <div class="stats-row">
              <div class="stat">
                <div class="stat-label">🚴 Your Efforts</div>
                <div class="stat-value orange"><%= seg.count %></div>
                <div class="stat-name">Last 90 days</div>
              </div>

              <div class="stat-divider">vs</div>

              <div class="stat">
                <div class="stat-label">📅 Same Period Last Year</div>
                <div class="stat-value <%= seg.lastYear === 0 ? 'muted' : (seg.count >= seg.lastYear ? 'green' : 'blue') %>">
                  <%= seg.lastYear || '—' %>
                </div>
                <div class="stat-name">
                  <% if (seg.lastYear > 0) { %>
                    <% if (seg.count > seg.lastYear) { %>
                      ↑ <%= seg.count - seg.lastYear %> ahead
                    <% } else if (seg.count === seg.lastYear) { %>
                      On pace
                    <% } else { %>
                      ↓ <%= seg.lastYear - seg.count %> behind
                    <% } %>
                  <% } else { %>
                    No data
                  <% } %>
                </div>
              </div>
            </div>

            <!-- Motivation message -->
            <div class="efforts-msg">
              <span class="msg-normal"><%= seg.motivation %></span>
            </div>

            <!-- Goal progress bar -->
            <% if (seg.goal > 0) { %>
              <div class="progress-container">
                <div class="progress-track">
                  <div
                    class="progress-fill"
                    style="width: <%= seg.progress %>%"
                    title="<%= seg.progress %>% of goal"
                  ></div>
                </div>
                <span class="progress-pct"><%= seg.progress %>%</span>
              </div>
              <p class="goal-label">Goal: <strong><%= seg.goal %> efforts</strong></p>
            <% } %>

            <!-- Goal setting form -->
            <details class="goal-details">
              <summary class="goal-summary">
                <%= seg.goal > 0 ? '✏️ Update goal' : '🎯 Set a goal' %>
              </summary>
              <form
                class="goal-form"
                action="/goals/<%= seg.id %>"
                method="POST"
              >
                <label for="goal-<%= seg.id %>">Target efforts:</label>
                <input
                  id="goal-<%= seg.id %>"
                  type="number"
                  name="target"
                  min="1"
                  max="999"
                  value="<%= seg.goal || '' %>"
                  placeholder="e.g. 10"
                  class="goal-input"
                >
                <button type="submit" class="btn-set-goal">Save</button>
                <% if (seg.goal > 0) { %>
                  <button
                    type="submit"
                    name="target"
                    value="0"
                    class="btn-clear-goal"
                  >Clear</button>
                <% } %>
              </form>
            </details>

            <!-- Actions -->
            <div class="card-actions">
              <a
                href="/card/<%= seg.id %>"
                class="btn-download"
                target="_blank"
                rel="noopener"
              >
                📥 Download Card
              </a>
              <button
                class="btn-preview"
                onclick="previewCard('<%= seg.id %>', this)"
              >
                🖼 Preview
              </button>
            </div>

            <!-- Inline preview -->
            <div class="preview-area" id="preview-<%= seg.id %>" style="display:none">
              <img class="preview-img" src="" alt="Share card preview" loading="lazy">
              <p class="preview-hint">Right-click to save, or use the download button above.</p>
            </div>

          </div>
        <% }) %>
      </div>

    <% } else if (!error) { %>
      <div class="empty-state">
        <div class="empty-icon">🚴</div>
        <h2>No segments found</h2>
        <p>Make sure your recent Strava activities have segment efforts enabled and are set to public.</p>
        <a href="/dashboard" class="btn-refresh">🔄 Refresh</a>
      </div>
    <% } %>

  </main>

  <footer class="footer">
    <!-- Powered by Strava — required attribution per Strava API Terms -->
    <a href="https://www.strava.com" target="_blank" rel="noopener" class="powered-by-strava" aria-label="Powered by Strava">
      <svg class="strava-badge-logo" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M15.387 17.944l-2.089-4.116h-3.065L15.387 24l5.15-10.172h-3.066l-2.084 4.116z"/>
        <path d="M11.16 8.71H8.397L15.387 0 22.377 8.71h-2.763l-4.227-5.766-4.227 5.766z"/>
      </svg>
      <span>Powered by Strava</span>
    </a>
    <span class="footer-divider">·</span>
    <span>Your data only — no other athletes</span>
    <span class="footer-divider">·</span>
    <a href="/privacy" class="footer-link">Data &amp; Privacy</a>
  </footer>

  <script>
    async function previewCard(segmentId, btn) {
      const area = document.getElementById('preview-' + segmentId);
      const img  = area.querySelector('.preview-img');

      if (area.style.display !== 'none') {
        area.style.display = 'none';
        btn.textContent = '🖼 Preview';
        return;
      }

      btn.textContent = '⏳ Generating…';
      btn.disabled = true;

      try {
        const res = await fetch('/card-preview/' + segmentId);
        if (!res.ok) throw new Error('Failed');
        const blob = await res.blob();
        img.src = URL.createObjectURL(blob);
        area.style.display = 'block';
        btn.textContent = '✕ Hide';
      } catch (e) {
        btn.textContent = '❌ Error – try again';
      } finally {
        btn.disabled = false;
      }
    }
  </script>
</body>
</html>
